layout(set = 0, binding = 0) uniform sampler2D sceneTexture;

layout(set = 0, binding = 1) uniform sampler2D depthTexture;

layout(location = 0) in vec2 inUV;

layout(location = 0) out vec4 outColor;

layout(push_constant) uniform PushConstants {
    int hdrEnable;
    float exposure;
    int dithering;
    int vga;
    float time;
} pc;

float rand(vec3 co) {
    return fract(sin(dot(co, vec3(12.9898, 78.233, 45.164))) * 43758.5453);
}

void main() {

    vec3 color = texture(sceneTexture, inUV).rgb;

    // DITHERING
    if (pc.dithering != 0) {
        float noise = rand(vec3(gl_FragCoord.xy, pc.time * 1000.0f));
        color += (noise - 0.5) / 256.0;
    }

    // HDR
    if (pc.hdrEnable != 0) {

        // EXPOSURE
        color *= pc.exposure;

        // TONEMAPPING HDR --> SDR
        color = color / (1.0 + color);

    } else {

        // HDR VALUES NORMALIZATION
        float maxValue = max(color.r, max(color.g, color.b));
        if (maxValue > 1.0) color /= maxValue;

    }

    // VGA PALETTE
    if (pc.vga != 0) {
        float bestDistance = 999999.0;
        int bestIndex = 0;

        for (int i = 0; i < 256; i++) {
            float d = distance(color, palette[i]);
            if (d < bestDistance) {
                bestDistance = d;
                bestIndex = i;
            }
        }

        color = palette[bestIndex];
    }


    outColor = vec4(color, 1.0);

}
